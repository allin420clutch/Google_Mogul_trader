rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: {userId}
    // Fields:
    //   - numAssetsToWatch: number (required)
    //   - alertThreshold: number (required)
    //   - role: string (required)
    //
    // Collection: users/{userId}/watchlist
    // Document ID: {assetId}
    // Fields:
    //   - id: string (required)
    //   - name: string (required)
    //   - symbol: string (required)
    //   - dateOfEntry: string (required)
    //   - dailyData: list (required)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "c53421571@gmail.com" && request.auth.token.email_verified == true));
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    function isValidUserProfile(data) {
      return hasOnlyAllowedFields(['numAssetsToWatch', 'alertThreshold', 'role', 'balance']) &&
             data.numAssetsToWatch is number && data.numAssetsToWatch >= 1 && data.numAssetsToWatch <= 10 &&
             data.alertThreshold is number && data.alertThreshold >= 0.1 && data.alertThreshold <= 100 &&
             data.balance is number &&
             data.role in ['admin', 'user'];
    }

    function isValidWatchlistItem(data) {
      return hasOnlyAllowedFields(['id', 'name', 'symbol', 'dateOfEntry', 'dailyData']) &&
             data.id is string && data.id.size() > 0 &&
             data.name is string && data.name.size() > 0 &&
             data.symbol is string && data.symbol.size() > 0 &&
             data.dateOfEntry is string &&
             data.dailyData is list;
    }

    function isValidHolding(data) {
      return hasOnlyAllowedFields(['assetId', 'symbol', 'name', 'amount', 'averageCost', 'totalCostBasis']) &&
             data.assetId is string && data.symbol is string && data.name is string &&
             data.amount is number && data.averageCost is number && data.totalCostBasis is number;
    }

    function isValidTransaction(data) {
      return hasOnlyAllowedFields(['id', 'assetId', 'symbol', 'type', 'amount', 'price', 'total', 'timestamp']) &&
             data.assetId is string && data.type in ['BUY', 'SELL'] &&
             data.amount is number && data.price is number && data.total is number;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isAuthenticated() && isValidUserProfile(request.resource.data) && ((isOwner(userId) && request.resource.data.role == 'user') || isAdmin());
      allow update: if isAuthenticated() && isValidUserProfile(request.resource.data) && ((isOwner(userId) && request.resource.data.role == resource.data.role) || isAdmin());
      allow delete: if isOwner(userId) || isAdmin();

      match /watchlist/{assetId} {
        allow read: if isOwner(userId) || isAdmin();
        allow create: if isOwner(userId) && isValidWatchlistItem(request.resource.data);
        allow update: if isOwner(userId) && isValidWatchlistItem(request.resource.data);
        allow delete: if isOwner(userId) || isAdmin();
      }

      match /holdings/{assetId} {
        allow read: if isOwner(userId) || isAdmin();
        allow create, update: if isOwner(userId) && isValidHolding(request.resource.data);
        allow delete: if isOwner(userId) || isAdmin();
      }

      match /transactions/{txId} {
        allow read: if isOwner(userId) || isAdmin();
        allow create: if isOwner(userId) && isValidTransaction(request.resource.data);
      }
    }
  }
}
